{
  "name": "wastech-mdlint",
  "version": "0.0.0",
  "description": "CLI for auditing Markdown context in repositories.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VladimirMakarevich/wastech-mdlint.git"
  },
  "homepage": "https://github.com/VladimirMakarevich/wastech-mdlint#readme",
  "bugs": {
    "url": "https://github.com/VladimirMakarevich/wastech-mdlint/issues"
  },
  "keywords": [
    "markdown",
    "audit",
    "cli",
    "documentation",
    "llm",
    "agents"
  ],
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24.17.0"
  },
  "scripts": {
    "build": "tsc -b",
    "generate:docs": "node scripts/generate-docs.mjs",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --check .",
    "prepack": "npm run build",
    "release:check": "npm run typecheck && npm test && npm run build && npm pack --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
