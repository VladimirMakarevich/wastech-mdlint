{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "wastech-mdlint configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "include": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "respectGitignore": {
      "type": "boolean"
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "siteRouter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "preset": {
              "type": "string"
            },
            "contentDir": {
              "type": "string"
            },
            "defaultLocale": {
              "type": "string"
            }
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "rule": {
                "const": "custom"
              },
              "id": {
                "type": "string",
                "pattern": "^[A-Z][A-Z0-9]*(-[A-Z0-9]+)+$"
              },
              "description": {
                "type": "string"
              },
              "severity": {
                "enum": [
                  "error",
                  "warning",
                  "off"
                ]
              },
              "target": {
                "enum": [
                  "checklist",
                  "content",
                  "link",
                  "section",
                  "table"
                ]
              },
              "options": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "exclude": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "assert": {
                    "oneOf": [
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "requiredColumns"
                          },
                          "columns": {
                            "minItems": 1,
                            "type": "array",
                            "items": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "section": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "kind",
                          "columns"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "columnNotEmpty"
                          },
                          "column": {
                            "type": "string",
                            "minLength": 1
                          },
                          "section": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "kind",
                          "column"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "columnInSet"
                          },
                          "column": {
                            "type": "string",
                            "minLength": 1
                          },
                          "values": {
                            "minItems": 1,
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "caseSensitive": {
                            "type": "boolean"
                          },
                          "section": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "kind",
                          "column",
                          "values"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "columnMatches"
                          },
                          "column": {
                            "type": "string",
                            "minLength": 1
                          },
                          "pattern": {
                            "type": "string"
                          },
                          "flags": {
                            "type": "string"
                          },
                          "section": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "kind",
                          "column",
                          "pattern"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "columnUnique"
                          },
                          "column": {
                            "type": "string",
                            "minLength": 1
                          },
                          "idPattern": {
                            "type": "string"
                          },
                          "section": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "kind",
                          "column"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "crossColumn"
                          },
                          "when": {
                            "type": "object",
                            "properties": {
                              "column": {
                                "type": "string",
                                "minLength": 1
                              },
                              "equals": {
                                "type": "string"
                              },
                              "matches": {
                                "type": "string"
                              },
                              "notEmpty": {
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "column"
                            ],
                            "additionalProperties": false
                          },
                          "then": {
                            "type": "object",
                            "properties": {
                              "column": {
                                "type": "string",
                                "minLength": 1
                              },
                              "equals": {
                                "type": "string"
                              },
                              "matches": {
                                "type": "string"
                              },
                              "notEmpty": {
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "column"
                            ],
                            "additionalProperties": false
                          },
                          "section": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "kind",
                          "when",
                          "then"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "sectionPresent"
                          },
                          "sections": {
                            "minItems": 1,
                            "type": "array",
                            "items": {
                              "type": "string",
                              "minLength": 1
                            }
                          }
                        },
                        "required": [
                          "kind",
                          "sections"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "sectionOrder"
                          },
                          "order": {
                            "minItems": 1,
                            "type": "array",
                            "items": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "level": {
                            "type": "integer",
                            "exclusiveMinimum": 0,
                            "maximum": 9007199254740991
                          },
                          "section": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "kind",
                          "order"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "contentNotMatch"
                          },
                          "pattern": {
                            "type": "string"
                          },
                          "flags": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "kind",
                          "pattern"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "noPlaceholders"
                          },
                          "section": {
                            "type": "string"
                          },
                          "placeholders": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "allChecked"
                          },
                          "section": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "linkResolves"
                          },
                          "exclude": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "imageResolves"
                          },
                          "exclude": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      }
                    ]
                  }
                },
                "required": [
                  "assert"
                ]
              }
            },
            "required": [
              "rule",
              "id",
              "options"
            ]
          }
        ]
      }
    },
    "compile": {
      "type": "object"
    }
  }
}
