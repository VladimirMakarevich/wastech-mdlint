dist/
*.tsbuildinfo
coverage/
.vitest/
node_modules/
.npm/
.pnpm-store/
yarn-error.log

# wastech-orchestrator runtime home (auto-appended by `worc install`)
# Ignore the runtime home's contents (not the dir itself) so flows/ can be re-included:
# Git won't descend into a fully-excluded dir, so `.worc/` would make any !.worc/flows a no-op.
.worc/*
!.worc/flows/

# orchestrator task files: authored/moved locally, committed by worc on the task branch
# (not tracked on main — avoids pending->done lifecycle churn on the base branch)
tasks/
